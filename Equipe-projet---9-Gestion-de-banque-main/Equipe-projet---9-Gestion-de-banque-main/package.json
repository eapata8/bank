{
  "name": "gestion-banque-equipe-9",
  "version": "1.0.0",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "postinstall": "npm --prefix frontend install",
    "dev:back": "nodemon server/index.js",
    "dev:front": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\"",
    "start": "node server/index.js",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "db:init": "node database/init-db.js",
    "db:migrate": "node database/migrate.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --config jest.config.cjs",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --config jest.config.cjs",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage --config jest.config.cjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^30.3.0",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "glob": "^13",
    "jsdom": "^29"
  }
}
